---
import BaseLayout from "../layouts/BaseLayout.astro";
import MediaGallery from "../components/Gallery";
import { getCollection } from "astro:content";
import { mapToMediaItem } from "../lib/mapToMediaItem";

const projects = await getCollection("media");

const homeProjects = projects
  .filter((p) => p.data.homepage)
  .map(mapToMediaItem);

const t = {
  title: "Naama Ofir",
 description: "Video editor, motion designer and 3D character animator. Discover commercial projects, branded content, animation and photography by Naama Ofir."
};
---

<BaseLayout pageTitle={t.title} description={t.description}>
  <MediaGallery items={homeProjects} client:visible />
   <!-- Load identity widget RAW -->
    <script is:inline>
      var script = document.createElement("script");
      script.src = "https://identity.netlify.com/v1/netlify-identity-widget.js";
      script.defer = true;
      document.head.appendChild(script);
    </script>
<script is:inline>
  document.addEventListener("DOMContentLoaded", function () {
    if (window.netlifyIdentity) {
      window.netlifyIdentity.on("init", function (user) {
        if (!user && window.location.hash.includes("invite_token")) {
          window.netlifyIdentity.open();
        }
      });

      window.netlifyIdentity.on("login", function () {
        window.location.href = "/admin/";
      });
    }
  });
</script>

</BaseLayout>
