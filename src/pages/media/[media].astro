---
import BaseLayout from "../../layouts/BaseLayout.astro";
import MediaGallery from "../../components/Gallery";
import { getCollection } from "astro:content";
import { mapToMediaItem } from "../../lib/mapToMediaItem";
import { Title } from "../../components/ui";

export async function getStaticPaths() {
  const items = await getCollection("media");

  const types = [...new Set(items.map((item) => item.data.type))];
  return types.map((type) => ({
    params: { media: type },
  }));
}

const { media } = Astro.params;

const allItems = await getCollection("media");

const filtered = allItems
  .filter((item) => item.data.type === media)
  .map(mapToMediaItem);

const t = {
  video_and_motion: {title: "Video & Motion", description:"Professional video editing portfolio by Naama Ofir, featuring commercial projects, branded content, music videos and cinematic storytelling.",},
  photography: {title: "Photography", description:"Selected photography works including commercial shoots, brand visuals and creative projects by Naama Ofir."},
   animation: {title: "3D animation", description:"3D animation and motion design projects including product visuals, branded animations and creative storytelling.",}

};
const content = t[media]
const pagename = 'Naama Ofir | ' + content.title
---

<BaseLayout pageTitle={pagename} description={content.description}>
  <Title text={content.title} size="lg" className="mb-6" />
  <MediaGallery items={filtered} client:visible />
</BaseLayout>
