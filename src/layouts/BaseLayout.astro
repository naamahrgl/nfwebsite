---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

interface Props {
  pageTitle: string;
description: string
}

const { pageTitle, description} = Astro.props;
---

<html >
  <head>
<!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-866E307NG1"></script>

<script is:inline>
  window.dataLayer = window.dataLayer || [];

  function gtag(){
    window.dataLayer.push(arguments);
  }

  gtag('js', new Date());
  gtag('config', 'G-866E307NG1');
</script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="canonical" href={Astro.url.href} />
  <link rel="sitemap" href="/sitemap-index.xml" />

    <title>{pageTitle}</title>
    <meta name="description" content={description } />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
<meta property="og:type" content="website" />
<meta property="og:url" content="https://naamaofir.com/" />

<meta property="og:image" content="https://naamaofir.netlify.app/ogimage.png" />
<meta property="og:image:type" content="image/png" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:image" content="https://naamaofir.netlify.app/ogimage.png" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={description} />

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Naama Ofir",
  "jobTitle": "Video Editor",
  "url": "https://naamaofir.com",
  "sameAs": [
    "https://www.linkedin.com/in/naama-ofir-546750180",
        "https://vimeo.com/naama87368545"

  ]
}
</script>


  </head>

<body class="relative overflow-x-hidden bg-[var(--main)] text-white font-sans">
  <div class="min-h-screen ">
    <Header />

    <main class="relative flex flex-col items-center justify-between">
      <slot />
    </main>
  </div>

  <Footer />
</body>

</html>
